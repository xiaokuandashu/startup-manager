{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "自启精灵",
  "version": "0.2.7",
  "identifier": "com.a.startup-manager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "自启精灵",
        "width": 1440,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 600,
        "decorations": true,
        "center": true,
        "theme": "Light"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "languages": ["SimpChinese"],
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "headerImage": null
      }
    }
  }
}
