{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "自启精灵",
  "version": "0.2.10",
  "identifier": "com.a.startup-manager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "自启精灵",
        "width": 1440,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 600,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis"],
    "externalBin": ["binaries/llama-server"],
    "resources": [
      "binaries/*.dll",
      "binaries/llama-server-x86_64-pc-windows-msvc.exe"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "frameworks": [
        "binaries/libggml-base.0.dylib",
        "binaries/libggml-blas.0.dylib",
        "binaries/libggml-cpu.0.dylib",
        "binaries/libggml-metal.0.dylib",
        "binaries/libggml-rpc.0.dylib",
        "binaries/libggml.0.dylib",
        "binaries/libllama.0.dylib",
        "binaries/libmtmd.0.dylib"
      ]
    },
    "windows": {
      "nsis": {
        "languages": ["SimpChinese"],
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "headerImage": null
      }
    }
  }
}
